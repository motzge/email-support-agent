# Ollama model used for all agent nodes
OLLAMA_MODEL=qwen3-coder:30b

# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# Hard timeout per LLM request in seconds
LLM_TIMEOUT_SECONDS=120

# Context window size passed to the model
LLM_NUM_CTX=4096

# Name used to sign generated draft replies
USER_NAME=The Support Team

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
